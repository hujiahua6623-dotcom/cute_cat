# cute_cat — 复制为 .env 并填写真实值；不要将 .env 提交到 Git

# MySQL（SQLAlchemy 连接串，驱动名按实现选型调整）
DATABASE_URL=mysql+asyncmy://user:password@127.0.0.1:3306/cute_cat_db

# Redis（可选：refresh token、限流、多 worker WS 映射）
REDIS_URL=redis://127.0.0.1:6379/0

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# 阿里云 DashScope（通义千问；周期 4+）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
QWEN_MODEL=qwen-plus

# CORS（开发示例）
CORS_ORIGINS=http://localhost:5173

# 公开访问基址（用于生成 WebSocket URL，如 ws://localhost:8000）
PUBLIC_BASE_URL=http://localhost:8000

# WebSocket 短期 ticket 有效期（秒）
WS_TICKET_TTL_SECONDS=60

# 游戏时间锚点（可选，ISO 8601；不填则自 Unix epoch 起算相对 gameDayIndex）
# SERVER_START_WALL_CLOCK=2026-01-01T00:00:00Z

# 前端（仅公开后端地址；复制 frontend/.env.example 为 frontend/.env 按需覆盖）
# VITE_API_BASE_URL=http://localhost:8000
